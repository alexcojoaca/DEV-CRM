// Multi-tenant Real Estate CRM - Prisma schema
// PostgreSQL (Supabase sau alt server)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Auth & multi-tenant ---

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String?
  createdAt    DateTime @default(now())

  memberships   WorkspaceMembership[]
  sentInvites   WorkspaceInvite[]       @relation("InvitedBy")
  fileAssets    FileAsset[]
  storageQuotas StorageQuota[]

  leadsCreated      Lead[]      @relation("LeadCreatedBy")
  leadsAssigned     Lead[]      @relation("LeadAssignedTo")
  clientsCreated    Client[]    @relation("ClientCreatedBy")
  clientsAssigned   Client[]    @relation("ClientAssignedTo")
  dealsCreated      Deal[]      @relation("DealCreatedBy")
  dealsAssigned     Deal[]      @relation("DealAssignedTo")
  propertiesCreated  Property[] @relation("PropertyCreatedBy")
  propertiesAssigned Property[] @relation("PropertyAssignedTo")

  viewingsCreated   Viewing[]  @relation("ViewingCreatedBy")
  viewingsAssigned  Viewing[]  @relation("ViewingAssignedTo")
  tasksCreated      Task[]     @relation("TaskCreatedBy")
  tasksAssigned     Task[]     @relation("TaskAssignedTo")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  memberships   WorkspaceMembership[]
  invites       WorkspaceInvite[]
  fileAssets    FileAsset[]
  storageQuotas StorageQuota[]
  leads         Lead[]
  clients       Client[]
  deals         Deal[]
  properties    Property[]
  viewings      Viewing[]
  tasks         Task[]
}

enum WorkspaceRole {
  OWNER
  MANAGER
  AGENT
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model WorkspaceInvite {
  id              String        @id @default(cuid())
  workspaceId     String
  invitedEmail    String
  role            WorkspaceRole
  invitedByUserId String
  status          InviteStatus  @default(PENDING)
  createdAt       DateTime      @default(now())
  acceptedAt      DateTime?

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy  User      @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([invitedEmail])
}

// --- File storage ---

enum FileEntityType {
  LISTING
  USER
  CLIENT
  DEAL
  OTHER
}

enum FileKind {
  IMAGE
  PDF
  DOC
  OTHER
}

model FileAsset {
  id               String        @id @default(cuid())
  workspaceId      String
  ownerUserId      String?
  entityType       FileEntityType
  entityId         String?
  kind             FileKind
  storagePath      String        @unique
  originalFileName String
  sizeBytes        Int
  mimeType         String
  createdAt        DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerUser User?     @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([entityType, entityId])
}

model StorageQuota {
  id         String   @id @default(cuid())
  workspaceId String
  userId     String?
  bytesLimit BigInt   @default(1073741824)
  bytesUsed  BigInt   @default(0)
  updatedAt  DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
}

// --- Domain entities (workspace-scoped, optional assignment) ---

model Lead {
  id          String   @id @default(cuid())
  workspaceId String
  assignedToUserId String?
  createdByUserId String?
  name        String
  phone       String
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo User?      @relation("LeadAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User?     @relation("LeadCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assignedToUserId])
}

model Client {
  id               String   @id @default(cuid())
  workspaceId      String
  assignedToUserId String?
  createdByUserId String?
  transactionType  String   @default("sale")
  propertyType     String   @default("apartment")
  name             String
  phone            String
  email            String?
  county           String?
  zone             String?
  roomsMin         Int?
  roomsMax         Int?
  surfaceMin       Int?
  surfaceMax       Int?
  budgetMin        Int?
  budgetMax        Int?
  constructionYearMin Int?
  status           String   @default("potential")
  source           String   @default("portal")
  notes            String?
  lastContactedAt DateTime?
  followUpCount    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("ClientAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User?     @relation("ClientCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assignedToUserId])
}

model Deal {
  id               String   @id @default(cuid())
  workspaceId      String
  assignedToUserId String?
  createdByUserId String?
  title            String?
  clientId         String?
  clientNameFree   String?
  clientPhoneFree  String?
  clientEmailFree  String?
  transactionType  String
  side             String
  status           String
  mainPropertyId   String?
  mainPropertyTitle String?
  mainPropertyPrice Float?
  commissionPercent Float?
  commissionReceivedTotal Float?
  listingPrice     Float?
  delistPrice      Float?
  notes            String?
  offersJson       Json?    @default("[]")
  matchedPropertiesJson Json? @default("[]")
  documentsJson    Json?    @default("[]")
  checklistJson    Json?    @default("[]")
  eventsJson       Json?    @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("DealAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User?     @relation("DealCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assignedToUserId])
}

model Viewing {
  id               String   @id @default(cuid())
  workspaceId      String
  propertyId       String?
  clientId         String?
  dealId           String?
  assignedToUserId String?
  createdByUserId  String
  propertyNameFree String?
  clientNameFree   String?
  clientPhoneFree  String?
  viewingType      String?  // "sale" | "rent"
  address          String?
  ownerName        String?
  ownerPhone       String?
  scheduledAt      DateTime?
  status           String   @default("scheduled") // scheduled | completed | cancelled | no_show
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("ViewingAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User      @relation("ViewingCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([assignedToUserId])
  @@index([propertyId])
  @@index([clientId])
  @@index([dealId])
}

model Property {
  id               String   @id @default(cuid())
  workspaceId      String
  assignedToUserId String?
  createdByUserId  String?
  transactionType  String
  type             String
  ownerName        String
  ownerPhone       String
  ownerEmail       String
  county           String
  zone             String?
  street           String
  number           String
  city             String
  title            String
  description      String?
  usefulArea       Int
  totalArea        Int?
  rooms            Int?
  bedrooms         Int?
  bathrooms        Int?
  price            Float
  priceCurrency    String   @default("EUR")
  status           String   @default("available")
  // Optional fields stored as JSON to keep schema manageable
  extraJson        Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("PropertyAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User?     @relation("PropertyCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assignedToUserId])
}

model Task {
  id               String   @id @default(cuid())
  workspaceId      String
  assignedToUserId String?
  createdByUserId  String
  title            String
  description      String?
  status           String   @default("open")
  priority         String   @default("medium")
  dueDate          DateTime
  relatedEntityType String?
  relatedEntityId   String?
  relatedEntityName String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("TaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User      @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([assignedToUserId])
}
