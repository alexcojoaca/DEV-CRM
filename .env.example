# Database – PostgreSQL (Supabase)
# Din Supabase: Project Settings → Database → Connection string
# Folosește "URI" pentru DIRECT_URL și "Session pooler" (port 5432) pentru DATABASE_URL
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PAROLA-DB]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres:[PAROLA-DB]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Supabase (pentru client/frontend dacă îl folosești mai târziu)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase (frontend / API)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Stocare fișiere în Supabase Storage (poze, PDF-uri, documente)
# Setează STORAGE_BACKEND=supabase și cheile de mai jos. Creează bucket-ul "crm-files" în Dashboard → Storage.
STORAGE_BACKEND=supabase
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=crm-files

# Alternativ: stocare locală pe disc (implicit dacă STORAGE_BACKEND nu e supabase)
UPLOAD_DIR="uploads"
